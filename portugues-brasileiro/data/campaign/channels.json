{
	"defaultChannels":[
		"news",
		"hegemony_public",
		"tritachyon_public",
		"player_intel_always",
		"local_comm",
		"secure_comm",
	],
	
	# messages sent on these channels will need to pass the same intel check as intercepts of comms
	# on other channels, but won't show an "intercepted by comm sniffer" note,
	# as conceptually they're an intel report based on data gleaned by comm sniffer,
	# rather than an actual intercept.
	"playerIntelChannels":[
		"player_intel",
	],
	
	"local_comm":{
		"name":"$sender",
		"logo":"graphics/icons/intel/comms64.png",
		"icon":"graphics/icons/intel/comms64.png",
		"image":"graphics/factions/player_flag.png",
		"sound":"ui_channel_comm_local",
		"type":"Comunicação Local",
		"shortType":"Com.",
	},
	"secure_comm":{
		"name":"$sender",
		"logo":"graphics/icons/intel/comms_secure64.png",
		"icon":"graphics/icons/intel/comms_secure64.png",
		"image":"graphics/factions/player_flag.png",
		"sound":"ui_channel_comm_secure",
		"type":"Canal de Comunicação Seguro",
		"shortType":"Com.",
	},
	"player_intel_always":{
		"name":"Análise e Projeções",
		"subChannelOf":"player_intel",
		"logo":"graphics/icons/intel/player.png",
		"icon":"graphics/icons/intel/player.png",
		"image":"graphics/factions/player_flag.png",
		"sound":"ui_channel_intel_assessment",
		"type":"Avaliação de Inteligência",
		"shortType":"Info",
	},
